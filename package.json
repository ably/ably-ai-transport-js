{
  "name": "@ably/ably-ai-transport-js",
  "version": "0.0.1",
  "description": "Ably transport and codecs for building AI applications with Ably.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .; (npm run format > /dev/null)",
    "format": "prettier --list-different --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "check:error-codes": "tsx scripts/validate-error-codes.ts",
    "precommit": "npm run format:check && npm run lint && npm run typecheck"
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ably/ably-ai-transport-js.git"
  },
  "keywords": [
    "ai",
    "ably",
    "ably-realtime",
    "transport",
    "websockets"
  ],
  "author": "Ably Realtime",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/ably/ably-ai-transport-js/issues"
  },
  "homepage": "https://github.com/ably/ably-ai-transport-js#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "ably": "^2.21.0",
    "ai": "^6",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.7",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.12.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.31.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^60.7.0",
    "eslint-plugin-prefer-arrow-functions": "^3.6.2",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^61.0.2",
    "globals": "^16.0.0",
    "jiti": "^2.6.1",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^4.1.0"
  }
}
